---
import Card from '../components/Card.astro'
---

<section class="py-16 lg:py-32">
  <div class="container flex flex-col gap-16">
    <div class="flex flex-col gap-4">
      <h2 class="text-neutral-700 text-3xl lg:text-4xl [&>strong]:font-medium">
        <strong>Why Join</strong> YOUTHX?
      </h2>
      <p class="text-neutral-500 lg:text-lg">
        At YOUTHX, we are dedicated to conducting ethical AI research, developing
        our own models, and publishing open scientific knowledge. We believe that
        technology must remain open—because if it is open, it is accessible; if it
        is open, it is transparent. Our mission is to explore, experiment, and
        share discoveries for the benefit of everyone.
      </p>
    </div>

    <ul class="grid grid-cols-1 lg:grid-cols-3 gap-8 xl:gap-16">
      <li>
        <Card
          type="primary"
          icon="star"
          title="Open by Design"
          description="We build technologies that are open, transparent, and accessible to all."
        />
      </li>
      <li>
        <Card
          type="light"
          icon="ellipse"
          title="Ethical AI"
          description="Our focus is on ethical research and responsible development of AI models."
        />
      </li>
      <li>
        <Card
          type="secondary"
          icon="square"
          title="Collective Knowledge"
          description="We publish our findings, write articles, and contribute to a global culture of shared science."
        />
      </li>
    </ul>
  </div>
</section>
